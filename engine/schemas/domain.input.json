{
  "type": "object",
  "additionalProperties": false,
  "required": [
    "slug",
    "bounded_contexts",
    "context_map",
    "open_questions"
  ],
  "properties": {
    "slug": {
      "type": "string",
      "description": "The project slug. Must match the slug of the source PRD. Example: deploy-rollback"
    },
    "bounded_contexts": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "name",
          "responsibility",
          "aggregates",
          "commands",
          "queries",
          "events"
        ],
        "properties": {
          "name": {
            "type": "string"
          },
          "responsibility": {
            "type": "string",
            "description": "Single sentence: what this context owns and is responsible for."
          },
          "aggregates": {
            "type": "array",
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": [
                "name",
                "root_entity",
                "entities",
                "invariants"
              ],
              "properties": {
                "name": {
                  "type": "string"
                },
                "root_entity": {
                  "type": "string"
                },
                "entities": {
                  "type": "array",
                  "items": {
                    "type": "string"
                  },
                  "description": "Must be a JSON array, never a string. Use [] for empty."
                },
                "invariants": {
                  "type": "array",
                  "items": {
                    "type": "string"
                  },
                  "description": "Business rules only. Not technical constraints. Must be a JSON array, never a string. Use [] for empty."
                }
              }
            },
            "description": "Must be a JSON array, never a string. Use [] for empty."
          },
          "commands": {
            "type": "array",
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": [
                "name",
                "description"
              ],
              "properties": {
                "name": {
                  "type": "string"
                },
                "description": {
                  "type": "string"
                }
              }
            },
            "description": "Must be a JSON array, never a string. Use [] for empty."
          },
          "queries": {
            "type": "array",
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": [
                "name",
                "description"
              ],
              "properties": {
                "name": {
                  "type": "string"
                },
                "description": {
                  "type": "string"
                }
              }
            },
            "description": "Must be a JSON array, never a string. Use [] for empty."
          },
          "events": {
            "type": "array",
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": [
                "name",
                "description"
              ],
              "properties": {
                "name": {
                  "type": "string"
                },
                "description": {
                  "type": "string"
                }
              }
            },
            "description": "Must be a JSON array, never a string. Use [] for empty."
          }
        }
      },
      "description": "Must be a JSON array, never a string. Use [] for empty."
    },
    "context_map": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "upstream",
          "downstream",
          "relationship"
        ],
        "properties": {
          "upstream": {
            "type": "string"
          },
          "downstream": {
            "type": "string"
          },
          "relationship": {
            "type": "string",
            "enum": [
              "shared-kernel",
              "customer-supplier",
              "anti-corruption-layer",
              "open-host",
              "conformist"
            ],
            "description": "DDD integration pattern between the two contexts."
          }
        }
      },
      "description": "Must be a JSON array, never a string. Use [] for empty."
    },
    "assumptions": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "description": "Modeling assumptions: beliefs about context ownership or aggregate boundaries that shaped the model but were not explicitly confirmed in the PRD. Non-blocking — you can proceed if they hold. Must be a JSON array, never a string. Use [] for empty."
    },
    "open_questions": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "description": "Unresolved domain ambiguities. Cross-session continuity signal. Must be a JSON array, never a string. Use [] for empty."
    },
    "decision_log_entry": {
      "type": "object",
      "description": "Entry to append to the artifact's decision_log. Omit on v1 if nothing meaningful to record.",
      "additionalProperties": false,
      "required": [
        "summary",
        "trigger",
        "changed_fields"
      ],
      "properties": {
        "summary": {
          "type": "string"
        },
        "trigger": {
          "type": "string",
          "enum": [
            "initial_draft",
            "human_feedback",
            "open_question_resolved",
            "scope_change"
          ]
        },
        "changed_fields": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "Must be a JSON array, never a string. Use [] for empty."
        }
      }
    }
  }
}