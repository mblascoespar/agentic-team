{
  "type": "object",
  "additionalProperties": false,
  "required": [
    "slug",
    "title",
    "problem",
    "target_users",
    "goals",
    "success_metrics",
    "scope_in",
    "scope_out",
    "features",
    "assumptions",
    "open_questions",
    "primary_archetype",
    "archetype_reasoning"
  ],
  "properties": {
    "slug": { "type": "string" },
    "source_idea": { "type": "string" },
    "title": { "type": "string" },
    "problem": { "type": "string" },
    "target_users": {
      "type": "array",
      "items": { "type": "string" },
      "minItems": 1
    },
    "goals": {
      "type": "array",
      "items": { "type": "string" },
      "minItems": 1
    },
    "success_metrics": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["metric", "measurement_method"],
        "properties": {
          "metric": { "type": "string" },
          "measurement_method": { "type": "string" }
        }
      }
    },
    "scope_in": {
      "type": "array",
      "items": { "type": "string" },
      "minItems": 1
    },
    "scope_out": {
      "type": "array",
      "items": { "type": "string" }
    },
    "features": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["name", "description", "user_story", "priority", "acceptance_criteria"],
        "properties": {
          "name": { "type": "string" },
          "description": { "type": "string" },
          "user_story": { "type": "string" },
          "priority": {
            "type": "string",
            "enum": ["must", "should", "could", "wont"]
          },
          "acceptance_criteria": {
            "type": "array",
            "items": { "type": "string" },
            "minItems": 1
          }
        }
      }
    },
    "assumptions": {
      "type": "array",
      "items": { "type": "string" }
    },
    "open_questions": {
      "type": "array",
      "items": { "type": "string" }
    },
    "primary_archetype": {
      "type": "string",
      "enum": ["domain_system", "data_pipeline", "system_integration", "process_system"],
      "description": "Primary classification of the system being built. Locked on v1 — cannot change on refinement turns."
    },
    "secondary_archetype": {
      "type": "string",
      "enum": ["process_system"],
      "description": "Optional secondary archetype. Only valid when primary is system_integration. Locked on v1."
    },
    "archetype_confidence": {
      "type": "string",
      "enum": ["high", "medium", "low"],
      "description": "Confidence in the archetype classification. May be revised on refinement turns."
    },
    "archetype_reasoning": {
      "type": "string",
      "minLength": 1,
      "description": "Explanation of why this archetype was chosen. Locked on v1."
    },
    "decision_log_entry": {
      "type": "object",
      "additionalProperties": false,
      "required": ["summary", "trigger", "changed_fields"],
      "properties": {
        "summary": { "type": "string" },
        "trigger": {
          "type": "string",
          "enum": ["initial_draft", "human_feedback", "open_question_resolved", "scope_change"]
        },
        "changed_fields": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    }
  }
}
